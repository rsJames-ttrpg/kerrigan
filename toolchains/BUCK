    name = "llvm-x86_64-linux",
    urls = ["https://github.com/llvm/llvm-project/releases/download/llvmorg-{}/LLVM-{}-Linux-X64.tar.xz".format(LLVM_VERSION, LLVM_VERSION)],
    sha256 = "ff32497b6801267ee427bc69cdaeecfb2d19578af8c2a942e864c45215f9a2ac",
    strip_prefix = "LLVM-{}-Linux-X64".format(LLVM_VERSION),
    visibility = ["PUBLIC"],
)

