CLAUDE_DRONE_SRCS = glob(["src/**/*.rs"])

# Config files live in src/config/ and must be listed in mapped_srcs so that
# Buck2 copies them into the __srcs sandbox alongside the .rs files, making
# them accessible to include_bytes! at compile time.
CLAUDE_DRONE_MAPPED_SRCS = {
    "src/config/settings.json": "src/config/settings.json",
    "src/config/CLAUDE.md": "src/config/CLAUDE.md",
    "//tools:claude-cli-linux-x64": "src/config/claude-cli",
    "//tools:drone-plugins-tar": "src/config/drone-plugins.tar",
}

CLAUDE_DRONE_DEPS = [
    "//src/drone-sdk:drone-sdk",
    "//third-party:anyhow",
    "//third-party:async-trait",
    "//third-party:base64",
    "//third-party:dirs",
    "//third-party:flate2",
    "//third-party:serde",
    "//third-party:serde_json",
    "//third-party:tar",
    "//third-party:tokio",
    "//third-party:tracing",
    "//third-party:tracing-subscriber",
]

rust_binary(
    name = "claude-drone",
    srcs = CLAUDE_DRONE_SRCS,
    mapped_srcs = CLAUDE_DRONE_MAPPED_SRCS,
    crate_root = "src/main.rs",
    deps = CLAUDE_DRONE_DEPS,
    visibility = ["PUBLIC"],
)

rust_test(
    name = "claude-drone-test",
    srcs = CLAUDE_DRONE_SRCS,
    mapped_srcs = CLAUDE_DRONE_MAPPED_SRCS,
    crate_root = "src/main.rs",
    deps = CLAUDE_DRONE_DEPS,
    visibility = ["PUBLIC"],
)
