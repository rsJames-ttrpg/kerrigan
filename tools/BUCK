)

# -- Claude Code plugins (vendored from anthropics/claude-plugins-official) ----
# Pinned to commit SHA for hermetic builds. Update by changing PLUGINS_COMMIT
# and regenerating SHA256: curl -sL <url>.tar.gz | sha256sum

PLUGINS_COMMIT = "104d39be10b7b1380b2ae23a387a11a297b599c3"
PLUGINS_SHA256 = "6f0e9b2b700be8d007811cd014d7a21e95697c82fbba95c0ae3036ed92d5af2f"

# Fetches official Claude Code plugins, pinned to a commit SHA.
http_archive(
    name = "claude-plugins-official",
    urls = ["https://github.com/anthropics/claude-plugins-official/archive/{}.tar.gz".format(PLUGINS_COMMIT)],
    sha256 = PLUGINS_SHA256,
    strip_prefix = "claude-plugins-official-{}/plugins".format(PLUGINS_COMMIT),
)

# -- Superpowers plugin (third-party, obra/superpowers) -----------------------
SUPERPOWERS_COMMIT = "b7a8f76985f1e93e75dd2f2a3b424dc731bd9d37"
SUPERPOWERS_SHA256 = "8bba19c7ca182cd5e33a565ce882db13ff4bb80a1c2034c823039ccacfbc8ff6"

http_archive(
    name = "superpowers-plugin",
    urls = ["https://github.com/obra/superpowers/archive/{}.tar.gz".format(SUPERPOWERS_COMMIT)],
    sha256 = SUPERPOWERS_SHA256,
    strip_prefix = "superpowers-{}".format(SUPERPOWERS_COMMIT),
)

# Bundle selected plugins into a tarball for embedding in the drone binary.
# Stages into cache/<namespace>/<plugin>/<version>/ structure matching
# Claude Code's installed_plugins.json discovery paths.
# Uses cp -rL to dereference http_archive symlinks.
genrule(
    name = "drone-plugins-tar",
    srcs = [
        ":claude-plugins-official",
        ":superpowers-plugin",
        "//src/drones/claude/plugins:creep-discovery",
    ],
    out = "drone-plugins.tar",
    bash = """
        set -euo pipefail
        STAGING="$BUCK_SCRATCH_PATH/plugins"
        OFFICIAL="$PWD/$(location :claude-plugins-official)"
        SUPERPOWERS="$PWD/$(location :superpowers-plugin)"
        CREEP="$PWD/$(location //src/drones/claude/plugins:creep-discovery)"

        for plugin in pr-review-toolkit code-simplifier claude-code-setup feature-dev; do
            DEST="$STAGING/cache/claude-plugins-official/$plugin/vendored"
            mkdir -p "$DEST"
            cp -rL "$OFFICIAL/$plugin/." "$DEST/"
        done

        DEST="$STAGING/cache/claude-plugins-official/superpowers/vendored"
        mkdir -p "$DEST"
        cp -rL "$SUPERPOWERS/." "$DEST/"

        DEST="$STAGING/cache/kerrigan/creep-discovery/0.1.0"
        mkdir -p "$DEST"
        cp -rL "$CREEP/creep-discovery/." "$DEST/"

        tar -cf "$OUT" -C "$STAGING" cache
    """,
    visibility = ["PUBLIC"],
)

export_file(
    name = "toolchain-resolve",
    src = "toolchain-resolve.sh",
)

# -- hermetic toolchain wrappers -----------------------------------------------
# Produces a self-relocatable bin/ directory with cargo, rustc, rustdoc, rustfmt,
# and clippy-driver. Path resolved at runtime via readlink -f, not baked in.
# Usage: buck2 build root//tools:toolchain-bin --show-full-output

genrule(
    name = "toolchain-bin",
    srcs = [
        "toolchains//:rustc-x86_64-linux",
        "toolchains//:cargo-x86_64-linux",
        "toolchains//:rustfmt-x86_64-linux",
        "toolchains//:clippy-x86_64-linux",
        ":toolchain-resolve",
    ],
    out = "toolchain-bin",
    bash = """
        set -euo pipefail
        RUSTC_DIST="$PWD/$(location toolchains//:rustc-x86_64-linux)"
        RUSTFMT_DIST="$PWD/$(location toolchains//:rustfmt-x86_64-linux)"
        CARGO_DIST="$PWD/$(location toolchains//:cargo-x86_64-linux)"
        CLIPPY_DIST="$PWD/$(location toolchains//:clippy-x86_64-linux)"
        RESOLVE="$PWD/$(location :toolchain-resolve)"

        mkdir -p "$OUT/rustc-dist" "$OUT/cargo-dist" "$OUT/rustfmt-dist" "$OUT/bin"

        # Copy relevant subtrees, dereferencing symlinks so output is self-contained
        cp -rfL "$RUSTC_DIST"/. "$OUT/rustc-dist/"
        cp -rfL "$CARGO_DIST"/. "$OUT/cargo-dist/"
        cp -rfL "$RUSTFMT_DIST"/. "$OUT/rustfmt-dist/"
        # Only the clippy-driver binary; its sysroot lives in rustc-dist
        cp -L "$CLIPPY_DIST/bin/clippy-driver" "$OUT/bin/clippy-driver-bin"
        # Resolver script — wrappers source this to find TOOLCHAIN_ROOT.
        # Kept in a separate file to avoid subshell syntax that conflicts
        # with Buck2 arg macro parsing.
        cp "$RESOLVE" "$OUT/bin/_resolve.sh"

        # Write thin wrappers that source the resolver and exec the real binary.
        # Uses ${0%/*} (parameter expansion, no subshell) to find _resolve.sh
        # relative to the wrapper — keeps wrappers self-relocatable.
        write_wrapper() {
            local name="$1" exec_path="$2"
            echo '#!/usr/bin/env bash' > "$OUT/bin/$name"
            echo 'source "${0%/*}/_resolve.sh"' >> "$OUT/bin/$name"
            echo 'exec "$TOOLCHAIN_ROOT/'"$exec_path"'" "$@"' >> "$OUT/bin/$name"
            chmod +x "$OUT/bin/$name"
        }

        write_wrapper cargo   "cargo-dist/bin/cargo"
        write_wrapper rustc   "rustc-dist/bin/rustc"
        write_wrapper rustdoc "rustc-dist/bin/rustdoc"
        write_wrapper rustfmt "rustfmt-dist/bin/rustfmt"
        write_wrapper clippy-driver "bin/clippy-driver-bin"
    """,
    visibility = ["PUBLIC"],
)
