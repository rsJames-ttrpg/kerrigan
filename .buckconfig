[cells]
  root = .
  prelude = prelude
  toolchains = toolchains
  platforms = platforms
  none = none

[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = none
  fbsource = none
  fbcode_macros = none
  buck = none

# Uses a copy of the prelude bundled with the buck2 binary. You can alternatively delete this
# section and vendor a copy of the prelude to the `prelude` directory of your project.
[external_cells]
  prelude = bundled

[parser]
  target_platform_detector_spec = target:root//...->platforms//:default \
    target:prelude//...->platforms//:default \
    target:toolchains//...->platforms//:default

[build]
  execution_platforms = platforms//:default

[buck2_re_client]
  engine_address = grpcs://remote.buildbuddy.io
  action_cache_address = grpcs://remote.buildbuddy.io
  cas_address = grpcs://remote.buildbuddy.io
  http_headers = x-buildbuddy-api-key:$BUILDBUDDY_API_KEY
