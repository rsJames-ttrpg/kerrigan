[cells]
  root = .
  prelude = prelude
  toolchains = toolchains
  platforms = platforms
  none = none

[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = none
  fbsource = none
  fbcode_macros = none
  buck = none

# Vendored prelude (patched transitive_dependency_symlinks.py mkdir + symlink bugs)

[parser]
  target_platform_detector_spec = target:root//...->platforms//:default \
    target:prelude//...->platforms//:default \
    target:toolchains//...->platforms//:default

[build]
  execution_platforms = platforms//:default

[project]
  remote_enabled = true

[buck2]
sqlite_materializer_state = true
digest_algorithms = SHA256

[buck2_re_client]
  engine_address = remote.buildbuddy.io
  action_cache_address = remote.buildbuddy.io
  cas_address = remote.buildbuddy.io
  http_headers = x-buildbuddy-api-key:$BUILDBUDDY_API_KEY
